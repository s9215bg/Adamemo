rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "s9215bg@gmail.com";
    }

    match /items/{itemId} {
      // Public visitors can read shared content. Only the configured
      // Firebase Auth admin can create, edit, or delete items.
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/admin {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
