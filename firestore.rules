rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /items/{itemId} {
      // Public visitors can read shared content, but writes must not be
      // trusted from the browser. Add Firebase Auth or a backend write path
      // before enabling edits again.
      allow read: if true;
      allow write: if false;
    }

    match /settings/admin {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
